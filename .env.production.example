# Production environment (copy to .env on server)
PUBLIC_APP_URL=https://pass.mstyle.ru
PUBLIC_API_URL=https://pass.mstyle.ru/api

JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=01.03.1986
ADMIN_FULL_NAME=Админ
ADMIN_ROLE=admin

# === SMTP (Spaceweb / mstyle.ru) ===
# SMTP_HOST=smtp.spaceweb.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=pass@mstyle.ru
# SMTP_PASS=your-password
# SMTP_FROM=Пропуск.М-Стиль <pass@mstyle.ru>
#
# Для локального теста (письма только в Mailpit UI :8025):
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Пропуск.М-Стиль <pass@mstyle.ru>

# === SMS Aero (регистрация по телефону) ===
# SMSAERO_EMAIL=your@smsaero.account
# SMSAERO_API_KEY=
# SMSAERO_SIGN=SMS Aero
# SMS_ENABLED=true

TZ=Europe/Moscow
# false — только 1 супер-админ при первом запуске, без тестовых аккаунтов
SEED_DEV_DATA=false