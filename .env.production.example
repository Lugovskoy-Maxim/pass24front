# Production environment (copy to .env on server)
PUBLIC_APP_URL=https://pass.mstyle.ru
PUBLIC_API_URL=https://pass.mstyle.ru/api

JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@pass24.local
ADMIN_PASSWORD=change-me-strong-password
ADMIN_FULL_NAME=Супер-администратор
ADMIN_ROLE=admin

# === SMTP (Spaceweb / mstyle.ru) ===
# SMTP_HOST=smtp.spaceweb.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=pass@mstyle.ru
# SMTP_PASS=your-password
# SMTP_FROM=M-STYLE PASS24 <pass@mstyle.ru>
#
# Для локального теста (письма только в Mailpit UI :8025):
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PASS24 <noreply@pass24.local>

TZ=Europe/Moscow
# false — только 1 супер-админ при первом запуске, без тестовых аккаунтов
SEED_DEV_DATA=false