# Docker environment variables for PASS24 stack
# Copy this file to .env in the project root if you want to customize

# MongoDB: по умолчанию Docker volume `mongo_data` (рекомендуется на Windows).
# Не задавайте MONGO_DATA_PATH, если не нужен bind mount.
# MONGO_DATA_PATH=./data/mongo

# You can also override backend variables here if needed
# MONGODB_URI will be set inside the compose file