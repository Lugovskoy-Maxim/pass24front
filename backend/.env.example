# Backend configuration
PORT=4000

# === MongoDB Connection ===
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/pass24

# MongoDB Atlas (recommended for development):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/pass24?retryWrites=true&w=majority

# JWT
JWT_SECRET=pass24-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Default admin (created on startup if not exists)
ADMIN_EMAIL=admin@pass24.local
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Администратор БЦ

# === Docker MongoDB settings ===
# Custom path for Mongo data when using docker compose (bind mount)
# MONGO_DATA_PATH=./data/mongo

# Frontend uses: NEXT_PUBLIC_API_URL=http://localhost:4000/api (see frontend/.env.local)

# === Email (SMTP) ===
# Docker Compose uses Mailpit by default (UI: http://127.0.0.1:8025)
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_FROM=PASS24 <noreply@pass24.local>
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# Public URL of the frontend (for links in emails)
# PUBLIC_APP_URL=http://127.0.0.1:3000

# CORS (optional, defaults allow local frontend)
# CORS_ORIGIN=http://localhost:3000